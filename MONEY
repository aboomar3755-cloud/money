<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Egg Game</title>
<style>
body {
    background: #0f172a;
    color: white;
    text-align: center;
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 20px;
}

h1 {
    margin-top: 20px;
}

.eggs-container {
    display: flex;
    justify-content: center;
    gap: 50px;
    margin-top: 50px;
    position: relative;
}

/* Eggs */
.egg {
    width: 100px;
    height: 140px;
    border-radius: 50% 50% 45% 45%;
    cursor: pointer;
    display: inline-block;
    position: relative;
    transition: transform 0.3s;
    border: 2px solid #fff;
    box-shadow: inset -5px -5px 0px rgba(0,0,0,0.1);
}

.egg.red { background: linear-gradient(to top, #f87171, #fca5a5); }
.egg.yellow { background: linear-gradient(to top, #facc15, #fde68a); }
.egg.blue { background: linear-gradient(to top, #3b82f6, #60a5fa); }

.egg:hover { transform: scale(1.1); }

/* Cracks */
.egg.cracked::before, .egg.cracked::after {
    content: '';
    position: absolute;
    width: 2px;
    height: 140px;
    background: #333;
    top: 0;
    left: 50%;
    transform: rotate(25deg);
}
.egg.cracked::after { transform: rotate(-25deg); }

/* Chick */
.chick {
    position: absolute;
    width: 120px;
    height: 120px;
    background: yellow;
    border-radius: 50%;
    top: -60px;
    left: -10px;
    display: none;
    font-weight: bold;
    font-size: 20px;
    color: #d97706;
    border: 2px solid orange;
    box-shadow: 0 0 15px orange;
    animation: pop 0.6s ease forwards;
}

/* Chick talking bubble */
.speech {
    position: absolute;
    top: -50px;
    left: 50%;
    transform: translateX(-50%);
    background: white;
    color: black;
    padding: 5px 10px;
    border-radius: 10px;
    font-size: 16px;
    display: none;
    opacity: 0;
    animation: bubble 0.5s forwards;
}

@keyframes pop {
    0% { transform: scale(0); opacity:0; }
    60% { transform: scale(1.3); opacity:1; }
    100% { transform: scale(1); opacity:1; }
}

@keyframes bubble {
    0% { transform: translate(-50%, -20px); opacity:0; }
    100% { transform: translate(-50%, -60px); opacity:1; }
}

/* TRY AGAIN button */
.btn {
    margin-top: 40px;
    padding: 12px 25px;
    background: linear-gradient(45deg, #22c55e, #4ade80);
    border: none;
    border-radius: 12px;
    color: black;
    font-weight: bold;
    font-size: 18px;
    cursor: pointer;
    display: none;
    transition: 0.3s;
}

.btn:hover { transform: scale(1.1); }

</style>
</head>
<body>

<h1>🥚 Click an Egg!</h1>

<div class="eggs-container">
    <div id="egg1" class="egg blue"></div>
    <div id="egg2" class="egg yellow"></div>
    <div id="egg3" class="egg red"></div>
</div>

<button id="retry" class="btn">TRY AGAIN</button>

<!-- Audio -->
<audio id="crackSound" src="https://www.soundjay.com/misc/sounds/break-egg-1.mp3"></audio>
<audio id="winSound" src="https://www.soundjay.com/button/sounds/button-3.mp3"></audio>

<script>
let lastReward = { egg1: null, egg2: null, egg3: null };
const eggs = ["egg1", "egg2", "egg3"];
const retry = document.getElementById("retry");
const crackSound = document.getElementById("crackSound");
const winSound = document.getElementById("winSound");

function getRandomReward(eggId){
    let rewards = [1,2,3];
    let filtered = rewards.filter(r=> r!==lastReward[eggId]);
    let random = filtered[Math.floor(Math.random()*filtered.length)];
    lastReward[eggId] = random;
    return random;
}

eggs.forEach(id=>{
    const egg = document.getElementById(id);
    egg.addEventListener("click", ()=>{
        egg.classList.add("cracked");
        crackSound.currentTime=0;
        crackSound.play();

        // Create chick
        const chick = document.createElement("div");
        chick.classList.add("chick");
        egg.appendChild(chick);

        // Create speech bubble
        const bubble = document.createElement("div");
        bubble.classList.add("speech");
        egg.appendChild(bubble);

        setTimeout(()=>{
            let reward = getRandomReward(id);
            bubble.textContent = `🐣 Congrats! You won $${reward}!`;
            chick.style.display = "block";
            bubble.style.display = "block";
            winSound.currentTime = 0;
            winSound.play();
            retry.style.display = "inline-block";
        },600);

        eggs.forEach(otherId=>{
            if(otherId!==id) document.getElementById(otherId).style.pointerEvents="none";
        });
    });
});

// Retry button
retry.addEventListener("click", ()=>{
    eggs.forEach(id=>{
        const egg=document.getElementById(id);
        egg.classList.remove("cracked");
        egg.style.opacity="1";
        egg.style.transform="scale(1)";
        egg.style.pointerEvents="auto";
        const chick=egg.querySelector(".chick");
        if(chick) egg.removeChild(chick);
        const bubble=egg.querySelector(".speech");
        if(bubble) egg.removeChild(bubble);
    });
    retry.style.display="none";
});
</script>

</body>
</html>
